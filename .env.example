# DayRoute Website Environment Variables
# Copy this file to .env.local and fill in the values
# These same variables must be set in Vercel → Settings → Environment Variables

# Supabase (required for waitlist API and database access)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend API Key for sending support + booking notification emails
# Get your API key from https://resend.com (free tier is fine).
# Booking emails are OPTIONAL — if this is blank, leads are still saved to the
# database and visible on /admin; only the email notification is skipped.
RESEND_API_KEY=
# Where booking notifications are sent, and the verified "from" address.
NOTIFY_EMAIL=
# Must be a Resend-verified domain, e.g. "DayRoute <hello@dayroute.com.au>".
RESEND_FROM=

# --- Leads CRM / Admin ( /admin ) -------------------------------------------
# Service role (SECRET) key from Supabase → Project Settings → API.
# Used SERVER-SIDE ONLY to read/manage leads. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Password you'll type to open the private /admin leads page. Pick a strong one.
ADMIN_PASSWORD=

# Optional: Google verification for Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=
