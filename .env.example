# DayRoute Website Environment Variables
# Copy this file to .env.local and fill in the values
# These same variables must be set in Vercel → Settings → Environment Variables

# Supabase (required for waitlist API and database access)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend API Key for sending support form emails
# Get your API key from https://resend.com
RESEND_API_KEY=

# Optional: Google verification for Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=
